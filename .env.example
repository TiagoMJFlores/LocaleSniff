# Provide one of these (or both — anthropic wins by default).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: anthropic | openai. If unset, the tool picks whichever key is set.
LOCALESNIFF_PROVIDER=

# Optional: a specific model id. Defaults to the provider's recommended model.
LOCALESNIFF_MODEL=

# Optional: default --since when not passed on the CLI.
LOCALESNIFF_DEFAULT_SINCE=origin/main
