{
  "name": "localesniff",
  "version": "0.1.0",
  "description": "Catches hardcoded user-facing strings in iOS and Android codebases before they ship. LLM-based, runs on a git diff.",
  "type": "module",
  "bin": {
    "localesniff": "bin/localesniff.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TiagoMJFlores/LocaleSniff.git"
  },
  "homepage": "https://github.com/TiagoMJFlores/LocaleSniff#readme",
  "bugs": {
    "url": "https://github.com/TiagoMJFlores/LocaleSniff/issues"
  },
  "license": "MIT",
  "author": "Tiago Flores",
  "keywords": [
    "i18n",
    "localization",
    "internationalization",
    "ios",
    "android",
    "swift",
    "kotlin",
    "mobile",
    "ci",
    "jenkins",
    "claude",
    "openai",
    "llm",
    "static-analysis"
  ],
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier -w .",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/openai": "^3.0.58",
    "ai": "^6.0.174",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.2",
    "fast-xml-parser": "^4.5.0",
    "p-limit": "^6.1.0",
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
